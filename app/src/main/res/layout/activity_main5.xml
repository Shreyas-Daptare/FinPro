<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Main5Activity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F8F9FA">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- Header Section -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:background="@color/colorPrimary">

                <TextView
                    android:id="@+id/stockNameTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:layout_marginHorizontal="64dp"
                    android:gravity="center"
                    android:text="COMPANY NAME"
                    android:textColor="#FFFFFF"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <!-- Upgraded to ImageButton for better click handling -->
                <ImageButton
                    android:id="@+id/backButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="Go Back"
                    android:elevation="8dp"
                    android:padding="16dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_keyboard_arrow_left_white_24dp"
                    android:tint="#FFFFFF"
                    android:visibility="invisible" />
            </RelativeLayout>

            <!-- 1. Stock Summary Metrics -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="Stock Summary Metrics"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#333333" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="12dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Price" android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/priceValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Loading..." android:textStyle="bold" android:textSize="16sp"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sector" android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/sectorValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="12dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="52 Week High" android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/high52Value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="52 Week Low" android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/low52Value" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Market Cap" android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/marketCapValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Volume" android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/volumeValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Company Summary Dropdown -->
            <LinearLayout
                android:id="@+id/summaryHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Summary"
                    android:textStyle="bold"
                    android:textSize="18sp"
                    android:textColor="#333333" />

                <ImageView
                    android:id="@+id/summaryArrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:rotation="90"
                    android:src="@drawable/ic_arrow_forward_black_24dp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:id="@+id/summaryCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">

                <TextView
                    android:id="@+id/businessSummaryValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp"
                    android:textSize="14sp"
                    android:textColor="#555555"
                    android:text="..." />
            </androidx.cardview.widget.CardView>

            <!-- 2. Stock Financials -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:text="Stock Financials"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#333333" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginBottom="12dp">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="P/B Ratio" android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/pbRatioValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Trailing P/E" android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/peTrailingValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2">
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Forward P/E" android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/peForwardValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold"/>
                        </LinearLayout>
                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="P/S Ratio" android:textSize="12sp" android:textColor="#888888"/>
                            <TextView android:id="@+id/psRatioValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 3. Analyst Ratings -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="Analyst Ratings"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#333333" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:weightSum="2">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rating (1-5)" android:textSize="12sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/recommendationMeanValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold" android:textSize="16sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Recommendation" android:textSize="12sp" android:textColor="#888888"/>
                        <TextView android:id="@+id/recommendationKeyValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold" android:textSize="16sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 4. Price Targets & Risk Scores -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginHorizontal="8dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_marginTop="8dp" android:text="Price Targets" android:textStyle="bold" android:textSize="16sp"/>
                    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="4dp" app:cardCornerRadius="12dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                            <TextView android:id="@+id/targetHigh" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="High: -" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/targetLow" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Low: -" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/targetMean" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mean: -" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/targetMedian" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Median: -" android:textSize="12sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_marginTop="8dp" android:text="Risk Scores" android:textStyle="bold" android:textSize="16sp"/>
                    <androidx.cardview.widget.CardView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_margin="4dp" app:cardCornerRadius="12dp">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="12dp">
                            <TextView android:id="@+id/auditRisk" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Audit: -" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/boardRisk" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Board: -" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/shRisk" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rights: -" android:textSize="12sp" android:layout_marginBottom="4dp"/>
                            <TextView android:id="@+id/overallRisk" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Overall: -" android:textSize="12sp"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="16dp"
                android:background="#DDDDDD" />

            <!-- 5. AI Overview -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="16dp"
                android:text="AI Overview"
                android:textStyle="bold"
                android:textSize="20sp"
                android:textColor="@color/colorPrimaryDark" />

            <Button
                android:id="@+id/predictButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginTop="8dp"
                android:text="Predict"
                android:textAllCaps="false" />

            <LinearLayout
                android:id="@+id/aiContentLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:text="Good Things"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/goodThingsList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="4dp"
                    android:textColor="#333333" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:text="Anomalies"
                    android:textStyle="bold"
                    android:textSize="16sp" />
                <TextView
                    android:id="@+id/anomaliesList"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="16dp"
                    android:layout_marginTop="4dp"
                    android:textColor="#F44336" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:weightSum="2" android:layout_marginTop="20dp" android:layout_marginHorizontal="16dp">
                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Rating" android:textSize="12sp"/>
                        <TextView android:id="@+id/aiRatingValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold" android:textSize="24sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Optimal Buy Price" android:textSize="12sp"/>
                        <TextView android:id="@+id/optimalPriceValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="-" android:textStyle="bold" android:textSize="24sp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
